# ---------- Server ----------
PORT=3000
NODE_ENV=development
# Public base URL Twilio will call (e.g. your ngrok / deploy URL)
PUBLIC_BASE_URL=http://localhost:3000

# ---------- Auth ----------
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
OTP_TTL_SECONDS=300

# ---------- Supabase (Project Settings > API) ----------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- WhatsApp provider ----------
# WHATSAPP_MOCK=true -> no real messages (logs instead). false -> send for real.
WHATSAPP_MOCK=true
# Which provider delivers WhatsApp: "twilio" or "meta".
WHATSAPP_PROVIDER=twilio

# ---------- Twilio WhatsApp (used when WHATSAPP_PROVIDER=twilio) ----------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---------- Meta WhatsApp Cloud API (used when WHATSAPP_PROVIDER=meta) ----------
# From: developers.facebook.com > your app > WhatsApp > API Setup
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
# Any string you choose — must match the "Verify token" in Meta > Configuration.
META_VERIFY_TOKEN=oasis_verify_2026
META_GRAPH_VERSION=v21.0

# ---------- Routing of internal alerts ----------
# Where "new request" alerts go (Service Manager WhatsApp, E.164).
# Active managers in the users table also receive alerts automatically.
MANAGER_WHATSAPP=+91XXXXXXXXXX
# Default country code prepended to bare local numbers entered by customers
DEFAULT_COUNTRY_CODE=+91

# ---------- Frontend ----------
CORS_ORIGIN=http://localhost:5173

# ---------- AI intake (Groq) ----------
# AI_INTAKE=true makes the WhatsApp agent use the LLM for natural conversation.
# Leave false to use the simple step-by-step flow. Get a FREE key at console.groq.com.
AI_INTAKE=false
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# ---------- Server ----------
PORT=3000
NODE_ENV=development
# Public base URL Twilio will call (e.g. your ngrok / deploy URL)
PUBLIC_BASE_URL=http://localhost:3000

# ---------- Auth ----------
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
OTP_TTL_SECONDS=300

# ---------- Supabase (Project Settings > API) ----------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- Twilio WhatsApp ----------
# Leave WHATSAPP_MOCK=true to run with NO real messages (logs instead).
# Set to false and fill the Twilio values to send real WhatsApp messages.
WHATSAPP_MOCK=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
# Twilio WhatsApp sender (sandbox default shown)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---------- Routing of internal alerts ----------
# Where "new request" alerts go (Service Manager WhatsApp, E.164).
# Active managers in the users table also receive alerts automatically.
MANAGER_WHATSAPP=+91XXXXXXXXXX
# Default country code prepended to bare local numbers entered by customers
DEFAULT_COUNTRY_CODE=+91

# ---------- Frontend ----------
CORS_ORIGIN=http://localhost:5173
